@model IEnumerable<Property>
@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Properties</h1>
    <a class="btn btn-primary" asp-action="Create">Add Property</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Units</th>
                    <th>Leases</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var property in Model)
                {
                    <tr>
                        <td>@property.Name</td>
                        <td>
                            <div>@property.Address</div>
                            <div class="text-muted small">@property.City, @property.State @property.ZipCode</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@property.Units.Count</div>
                            <div class="text-muted small">of @property.TotalUnits planned</div>
                        </td>
                        <td>@property.Leases.Count</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@property.Id">Details</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@property.Id">Edit</a>
                                <form asp-action="Delete" asp-route-id="@property.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this property?');">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
