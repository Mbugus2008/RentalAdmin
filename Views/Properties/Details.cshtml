@model Property
@{
    ViewData["Title"] = "Property Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">@Model.Name</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Address</div>
            <div class="card-body">
                <p class="mb-1">@Model.Address</p>
                <p class="mb-1">@Model.City, @Model.State @Model.ZipCode</p>
                <p class="mb-0 text-muted">Total units planned: @Model.TotalUnits</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Notes</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <p class="mb-0">@Model.Notes</p>
                }
                else
                {
                    <p class="text-muted mb-0">No notes recorded.</p>
                }
            </div>
        </div>
    </div>
</div>

<section class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Units (@Model.Units.Count of @Model.TotalUnits)</span>
        <div class="btn-group btn-group-sm">
            <a class="btn btn-outline-secondary" asp-controller="Units" asp-action="Index" asp-route-propertyId="@Model.Id">Manage Units</a>
            <a class="btn btn-outline-primary" asp-controller="Units" asp-action="Create" asp-route-propertyId="@Model.Id">Add Unit</a>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model.Units.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Unit</th>
                            <th>Type</th>
                            <th>Notes</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in Model.Units.OrderBy(u => u.UnitNumber))
                        {
                            <tr>
                                <td>@unit.UnitNumber</td>
                                <td>@unit.UnitType</td>
                                <td class="text-muted">
                                    @if (!string.IsNullOrWhiteSpace(unit.Notes))
                                    {
                                        @unit.Notes
                                    }
                                    else
                                    {
                                        <span class="fst-italic">No notes</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-secondary" asp-controller="Units" asp-action="Details" asp-route-id="@unit.Id">View</a>
                                        <a class="btn btn-outline-primary" asp-controller="Units" asp-action="Edit" asp-route-id="@unit.Id">Edit</a>
                                        <form asp-controller="Units" asp-action="Delete" asp-route-id="@unit.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete this unit?');">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">No units configured for this property yet.</div>
        }
    </div>
</section>

<section class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Active Leases</span>
        <a class="btn btn-outline-primary btn-sm" asp-controller="Leases" asp-action="Create">Add Lease</a>
    </div>
    <div class="card-body p-0">
        @if (Model.Leases.Count > 0)
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tenant</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Rent</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lease in Model.Leases.OrderByDescending(l => l.StartDate))
                        {
                            <tr>
                                <td>@lease.Tenant?.FullName</td>
                                <td>@lease.StartDate.ToString("MMM dd, yyyy")</td>
                                <td>@lease.EndDate?.ToString("MMM dd, yyyy")</td>
                                <td>@lease.MonthlyRent.ToString("C")</td>
                                <td><span class="badge bg-secondary">@lease.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">No leases associated with this property yet.</div>
        }
    </div>
</section>
