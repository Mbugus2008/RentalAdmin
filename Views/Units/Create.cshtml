@model Unit
@{
    ViewData["Title"] = "Add Unit";
    var propertyName = ViewData["PropertyName"] as string ?? "Property";
}

<h1 class="h3 mb-3">Add Unit</h1>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="alert alert-info small" role="status">
            Adding a unit to <strong>@propertyName</strong>.
        </div>
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="PropertyId" />
            <partial name="_UnitForm" />
            <div class="mt-4 d-flex justify-content-between">
                <a class="btn btn-secondary" asp-controller="Properties" asp-action="Details" asp-route-id="@Model.PropertyId">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Unit</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
