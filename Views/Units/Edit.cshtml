@model Unit
@{
    ViewData["Title"] = "Edit Unit";
    var hasProperties = ViewData["HasProperties"] as bool? ?? true;
}

<h1 class="h3 mb-3">Edit Unit</h1>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <partial name="_UnitForm" />
            <div class="mt-4 d-flex justify-content-between">
                @if (Model.PropertyId > 0)
                {
                    <a class="btn btn-secondary" asp-controller="Properties" asp-action="Details" asp-route-id="@Model.PropertyId">Cancel</a>
                }
                else
                {
                    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                }
                <button type="submit" class="btn btn-primary" @(hasProperties ? string.Empty : "disabled")>Update Unit</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
