@model Unit
@{
    ViewData["Title"] = "Unit Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">@Model.UnitType</h1>
    <div class="btn-group">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-primary" asp-action="Index" asp-route-propertyId="@Model.PropertyId">Back to Units</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Property</dt>
            <dd class="col-sm-9">
                <div class="fw-semibold">@Model.Property?.Name</div>
                <div class="text-muted small">@Model.Property?.Address</div>
                <div class="text-muted small">@Model.Property?.City, @Model.Property?.State @Model.Property?.ZipCode</div>
                <div class="mt-2">
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Properties" asp-action="Details" asp-route-id="@Model.PropertyId">View property</a>
                </div>
            </dd>
            <dt class="col-sm-3">Unit type</dt>
            <dd class="col-sm-9">@Model.UnitType</dd>
        </dl>
    </div>
</div>
