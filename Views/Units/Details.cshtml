@model Unit
@{
    ViewData["Title"] = "Unit Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Unit @Model.UnitNumber</h1>
    <div class="btn-group">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline-primary" asp-action="Index" asp-route-propertyId="@Model.PropertyId">Back to Units</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Property</div>
            <div class="card-body">
                <h2 class="h5">@Model.Property?.Name</h2>
                <p class="mb-1">@Model.Property?.Address</p>
                <p class="text-muted mb-0">@Model.Property?.City, @Model.Property?.State @Model.Property?.ZipCode</p>
                <div class="mt-3">
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Properties" asp-action="Details" asp-route-id="@Model.PropertyId">View property</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Unit details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Unit</dt>
                    <dd class="col-sm-8">@Model.UnitNumber</dd>
                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@Model.UnitType</dd>
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.Notes))
                        {
                            @Model.Notes
                        }
                        else
                        {
                            <span class="text-muted">No notes available.</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
