@model Tenant
@{
    ViewData["Title"] = "Tenant Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">@Model.FullName</h1>
    <div>
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Contact</div>
            <div class="card-body">
                <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
                <p class="mb-0"><strong>Phone:</strong> @Model.Phone</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Move-in Date</div>
            <div class="card-body">
                @if (Model.MoveInDate.HasValue)
                {
                    <p class="mb-0">@Model.MoveInDate.Value.ToString("MMM dd, yyyy")</p>
                }
                else
                {
                    <p class="text-muted mb-0">Not recorded.</p>
                }
            </div>
        </div>
    </div>
</div>

<section class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Lease History</span>
        <a class="btn btn-outline-primary btn-sm" asp-controller="Leases" asp-action="Create">Add Lease</a>
    </div>
    <div class="card-body p-0">
        @if (Model.Leases.Count > 0)
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Property</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Rent</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lease in Model.Leases.OrderByDescending(l => l.StartDate))
                        {
                            <tr>
                                <td>@lease.Property?.Name</td>
                                <td>@lease.StartDate.ToString("MMM dd, yyyy")</td>
                                <td>@lease.EndDate?.ToString("MMM dd, yyyy")</td>
                                <td>@lease.MonthlyRent.ToString("C")</td>
                                <td><span class="badge bg-secondary">@lease.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">No leases found for this tenant.</div>
        }
    </div>
</section>
