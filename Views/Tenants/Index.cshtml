@model IEnumerable<Tenant>
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Tenants</h1>
    <a class="btn btn-primary" asp-action="Create">Add Tenant</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Leases</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tenant in Model)
                {
                    <tr>
                        <td>@tenant.FullName</td>
                        <td>@tenant.Email</td>
                        <td>@tenant.Phone</td>
                        <td>@tenant.Leases.Count</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@tenant.Id">Details</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@tenant.Id">Edit</a>
                                <form asp-action="Delete" asp-route-id="@tenant.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this tenant?');">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
