@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-muted">Properties</h6>
                <div class="display-6 fw-bold">@Model.PropertyCount</div>
                <p class="text-muted small mb-0">Properties in portfolio</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-muted">Tenants</h6>
                <div class="display-6 fw-bold">@Model.TenantCount</div>
                <p class="text-muted small mb-0">Active residents</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-muted">Active Leases</h6>
                <div class="display-6 fw-bold">@Model.ActiveLeaseCount</div>
                <p class="text-muted small mb-0">Currently occupied</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-muted">Monthly Rent</h6>
                <div class="display-6 fw-bold">@Model.TotalMonthlyRent.ToString("C")</div>
                <p class="text-muted small mb-0">Scheduled this month</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="text-uppercase text-muted">Payments Received</h6>
                <div class="display-6 fw-bold text-success">@Model.PaymentsCollectedThisMonth.ToString("C")</div>
                <p class="text-muted small mb-0">Collected this month</p>
            </div>
        </div>
    </div>
</div>
