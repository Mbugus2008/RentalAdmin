@{
    var title = ViewData["Title"] as string ?? "Dashboard";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    bool IsCurrentController(string candidate)
    {
        return string.Equals(controller, candidate, StringComparison.OrdinalIgnoreCase);
    }

    bool IsCurrentAction(string controllerName, string actionName)
    {
        return IsCurrentController(controllerName) &&
            string.Equals(action, actionName, StringComparison.OrdinalIgnoreCase);
    }

    var controllerKey = controller.ToLowerInvariant();
    var activeTab = controllerKey switch
    {
        "properties" => "portfolio",
        "tenants" => "people",
        "leases" => "operations",
        "payments" => "operations",
        _ => "overview"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Rental Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-ribbon shadow-sm">
        <div class="container-fluid px-4">
            <div class="ribbon-topbar">
                <div class="ribbon-brand-block">
                    <div class="ribbon-brand">
                        <a class="ribbon-brand-title" asp-controller="Home" asp-action="Index">Rental Manager</a>
                        <span class="ribbon-brand-tagline">Portfolio Console</span>
                    </div>
                    <div class="ribbon-context">
                        <span class="ribbon-context-item">
                            <i class="bi bi-calendar-event" aria-hidden="true"></i>
                            @DateTime.Now.ToString("dddd, MMM d")
                        </span>
                        <span class="ribbon-context-item">
                            <i class="bi bi-flag" aria-hidden="true"></i>
                            Renewals focus
                        </span>
                    </div>
                </div>
                <div class="ribbon-quick-actions" role="toolbar" aria-label="Quick actions">
                    <a class="btn-ribbon btn-ribbon-primary@(IsCurrentAction("Properties", "Create") ? " active" : string.Empty)" asp-controller="Properties" asp-action="Create">
                        <i class="bi bi-building-add" aria-hidden="true"></i>
                        <span>New Property</span>
                    </a>
                    <a class="btn-ribbon@(IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Create">
                        <i class="bi bi-journal-plus" aria-hidden="true"></i>
                        <span>New Lease</span>
                    </a>
                    <a class="btn-ribbon@(IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                        <i class="bi bi-person-plus" aria-hidden="true"></i>
                        <span>Add Tenant</span>
                    </a>
                </div>
            </div>
            <div class="ribbon-body">
                <nav class="ribbon-tablist" role="tablist" aria-label="Ribbon menu">
                    <button type="button" class="ribbon-tab@(activeTab == "overview" ? " active" : string.Empty)" id="ribbon-tab-overview" data-ribbon-tab="overview" role="tab" aria-controls="ribbon-panel-overview" aria-selected="@(activeTab == "overview" ? "true" : "false")" tabindex="@(activeTab == "overview" ? "0" : "-1")">
                        Overview
                    </button>
                    <button type="button" class="ribbon-tab@(activeTab == "portfolio" ? " active" : string.Empty)" id="ribbon-tab-portfolio" data-ribbon-tab="portfolio" role="tab" aria-controls="ribbon-panel-portfolio" aria-selected="@(activeTab == "portfolio" ? "true" : "false")" tabindex="@(activeTab == "portfolio" ? "0" : "-1")">
                        Portfolio
                    </button>
                    <button type="button" class="ribbon-tab@(activeTab == "people" ? " active" : string.Empty)" id="ribbon-tab-people" data-ribbon-tab="people" role="tab" aria-controls="ribbon-panel-people" aria-selected="@(activeTab == "people" ? "true" : "false")" tabindex="@(activeTab == "people" ? "0" : "-1")">
                        People
                    </button>
                    <button type="button" class="ribbon-tab@(activeTab == "operations" ? " active" : string.Empty)" id="ribbon-tab-operations" data-ribbon-tab="operations" role="tab" aria-controls="ribbon-panel-operations" aria-selected="@(activeTab == "operations" ? "true" : "false")" tabindex="@(activeTab == "operations" ? "0" : "-1")">
                        Operations
                    </button>
                </nav>
                <div class="ribbon-surface">
                    <section class="ribbon-panel" id="ribbon-panel-overview" role="tabpanel" aria-labelledby="ribbon-tab-overview" data-ribbon-panel="overview" @(activeTab == "overview" ? string.Empty : "hidden") tabindex="0">
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Portfolio</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Home") ? " active" : string.Empty)" asp-controller="Home" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-speedometer2"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Dashboard</span>
                                        <span class="ribbon-command-description">Portfolio KPIs &amp; alerts</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentController("Properties") && !IsCurrentAction("Properties", "Create") ? " active" : string.Empty)" asp-controller="Properties" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-buildings"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Manage properties</span>
                                        <span class="ribbon-command-description">Buildings, units, and owners</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Residents &amp; Leases</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Tenants") && !IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-people"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Tenant directory</span>
                                        <span class="ribbon-command-description">Contacts and history</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-journal-check"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Active leases</span>
                                        <span class="ribbon-command-description">Terms, expirations, and status</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Financials</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " active" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-credit-card-2-front"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Payment ledger</span>
                                        <span class="ribbon-command-description">Receipts and balances</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Payments", "Create") ? " active" : string.Empty)" asp-controller="Payments" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Record payment</span>
                                        <span class="ribbon-command-description">Log rent collection</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Quick add</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentAction("Properties", "Create") ? " active" : string.Empty)" asp-controller="Properties" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-building-add"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">New property</span>
                                        <span class="ribbon-command-description">Capture a new asset</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-journal-plus"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">New lease</span>
                                        <span class="ribbon-command-description">Start a contract</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-person-plus"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Add tenant</span>
                                        <span class="ribbon-command-description">Onboard a new resident</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </section>
                    <section class="ribbon-panel" id="ribbon-panel-portfolio" role="tabpanel" aria-labelledby="ribbon-tab-portfolio" data-ribbon-panel="portfolio" @(activeTab == "portfolio" ? string.Empty : "hidden") tabindex="0">
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Asset management</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Properties") && !IsCurrentAction("Properties", "Create") ? " active" : string.Empty)" asp-controller="Properties" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-buildings"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Properties list</span>
                                        <span class="ribbon-command-description">Overview of every asset</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Properties", "Create") ? " active" : string.Empty)" asp-controller="Properties" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-building-add"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Add property</span>
                                        <span class="ribbon-command-description">Track a new community</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Occupancy</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-clipboard-data"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Lease pipeline</span>
                                        <span class="ribbon-command-description">Monitor expirations</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-arrow-repeat"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Start renewal</span>
                                        <span class="ribbon-command-description">Extend resident stays</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Residents</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Tenants") && !IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-people"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Tenant roster</span>
                                        <span class="ribbon-command-description">Match residents to units</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-person-plus"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Onboard tenant</span>
                                        <span class="ribbon-command-description">Capture resident details</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </section>
                    <section class="ribbon-panel" id="ribbon-panel-people" role="tabpanel" aria-labelledby="ribbon-tab-people" data-ribbon-panel="people" @(activeTab == "people" ? string.Empty : "hidden") tabindex="0">
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Directory</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Tenants") && !IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-card-list"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Resident directory</span>
                                        <span class="ribbon-command-description">Profiles, notes, and history</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Tenants", "Create") ? " active" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-person-plus"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Add resident</span>
                                        <span class="ribbon-command-description">Invite a new tenant</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Lease contacts</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-journal-check"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Active agreements</span>
                                        <span class="ribbon-command-description">Key contacts &amp; dates</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-pencil-square"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Draft lease</span>
                                        <span class="ribbon-command-description">Capture terms &amp; rent</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Account health</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " active" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-clipboard-check"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Billing status</span>
                                        <span class="ribbon-command-description">Open balances by resident</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Payments", "Create") ? " active" : string.Empty)" asp-controller="Payments" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Log payment</span>
                                        <span class="ribbon-command-description">Apply rent or deposits</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </section>
                    <section class="ribbon-panel" id="ribbon-panel-operations" role="tabpanel" aria-labelledby="ribbon-tab-operations" data-ribbon-panel="operations" @(activeTab == "operations" ? string.Empty : "hidden") tabindex="0">
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Lease workflow</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-journal-check"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Manage leases</span>
                                        <span class="ribbon-command-description">Review terms and renewals</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Leases", "Create") ? " active" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-journal-plus"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Create lease</span>
                                        <span class="ribbon-command-description">Launch a new agreement</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Receivables</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " active" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-credit-card-2-front"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Payment log</span>
                                        <span class="ribbon-command-description">Track rent collection</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentAction("Payments", "Create") ? " active" : string.Empty)" asp-controller="Payments" asp-action="Create">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Record receipt</span>
                                        <span class="ribbon-command-description">Apply a new payment</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                        <div class="ribbon-group">
                            <h3 class="ribbon-group-title">Portfolio tools</h3>
                            <div class="ribbon-commands">
                                <a class="ribbon-command@(IsCurrentController("Home") ? " active" : string.Empty)" asp-controller="Home" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-speedometer2"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Operations dashboard</span>
                                        <span class="ribbon-command-description">Live performance metrics</span>
                                    </span>
                                </a>
                                <a class="ribbon-command@(IsCurrentController("Properties") && !IsCurrentAction("Properties", "Create") ? " active" : string.Empty)" asp-controller="Properties" asp-action="Index">
                                    <span class="ribbon-command-icon" aria-hidden="true"><i class="bi bi-buildings"></i></span>
                                    <span class="ribbon-command-text">
                                        <span class="ribbon-command-label">Asset registry</span>
                                        <span class="ribbon-command-description">Ensure data accuracy</span>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </header>

    <main role="main" class="container py-4">
        @RenderBody()
    </main>

    <footer class="bg-light border-top py-3 mt-auto">
        <div class="container text-center text-muted small">
            &copy; @DateTime.Now.Year Rental Manager. Track leases, tenants, and payments at a glance.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/ribbon.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
