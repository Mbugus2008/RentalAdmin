@{
    var title = ViewData["Title"] as string ?? "Dashboard";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    bool IsCurrentController(string candidate)
    {
        return string.Equals(controller, candidate, StringComparison.OrdinalIgnoreCase);
    }

    bool IsCurrentAction(string controllerName, string actionName)
    {
        return IsCurrentController(controllerName) &&
            string.Equals(action, actionName, StringComparison.OrdinalIgnoreCase);
    }

    var controllerKey = controller.ToLowerInvariant();
    var activeTab = controllerKey switch
    {
        "properties" => "portfolio",
        "tenants" => "people",
        "leases" => "operations",
        "payments" => "operations",
        "home" => "home",
        _ => "home"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Rental Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="office-shell shadow-sm">
        <div class="container-fluid px-4">
            <div class="office-titlebar" role="presentation">
                <div class="office-titlebar-left">
                    <div class="office-quick-access" role="toolbar" aria-label="Quick access toolbar">
                        <a class="office-qa-button@(IsCurrentAction("Properties", "Create") ? " is-active" : string.Empty)" asp-controller="Properties" asp-action="Create" title="New property" aria-label="Create a new property">
                            <i class="bi bi-building-add" aria-hidden="true"></i>
                        </a>
                        <a class="office-qa-button@(IsCurrentAction("Leases", "Create") ? " is-active" : string.Empty)" asp-controller="Leases" asp-action="Create" title="New lease" aria-label="Create a new lease">
                            <i class="bi bi-journal-plus" aria-hidden="true"></i>
                        </a>
                        <a class="office-qa-button@(IsCurrentAction("Payments", "Create") ? " is-active" : string.Empty)" asp-controller="Payments" asp-action="Create" title="Record payment" aria-label="Record a payment">
                            <i class="bi bi-cash-coin" aria-hidden="true"></i>
                        </a>
                        <a class="office-qa-button@(IsCurrentAction("Tenants", "Create") ? " is-active" : string.Empty)" asp-controller="Tenants" asp-action="Create" title="Add tenant" aria-label="Add a tenant">
                            <i class="bi bi-person-plus" aria-hidden="true"></i>
                        </a>
                    </div>
                    <div class="office-brand">
                        <a class="office-brand__name" asp-controller="Home" asp-action="Index">Rental Manager</a>
                        <span class="office-brand__subtitle">Property console</span>
                    </div>
                </div>
                <div class="office-titlebar-right">
                    <div class="office-status">
                        <span class="office-status-chip">
                            <i class="bi bi-calendar-event" aria-hidden="true"></i>
                            @DateTime.Now.ToString("dddd, MMM d")
                        </span>
                        <span class="office-status-chip">
                            <i class="bi bi-flag-fill" aria-hidden="true"></i>
                            Renewals focus
                        </span>
                    </div>
                </div>
            </div>
            <div class="office-tabrow" role="tablist" aria-label="Ribbon tabs">
                <a class="office-file-button" asp-controller="Home" asp-action="Index">File</a>
                <button type="button" class="office-tab@(activeTab == "home" ? " is-active" : string.Empty)" id="office-tab-home" data-office-tab="home" role="tab" aria-controls="office-panel-home" aria-selected="@(activeTab == "home" ? "true" : "false")" tabindex="@(activeTab == "home" ? "0" : "-1")">
                    Home
                </button>
                <button type="button" class="office-tab@(activeTab == "portfolio" ? " is-active" : string.Empty)" id="office-tab-portfolio" data-office-tab="portfolio" role="tab" aria-controls="office-panel-portfolio" aria-selected="@(activeTab == "portfolio" ? "true" : "false")" tabindex="@(activeTab == "portfolio" ? "0" : "-1")">
                    Portfolio
                </button>
                <button type="button" class="office-tab@(activeTab == "people" ? " is-active" : string.Empty)" id="office-tab-people" data-office-tab="people" role="tab" aria-controls="office-panel-people" aria-selected="@(activeTab == "people" ? "true" : "false")" tabindex="@(activeTab == "people" ? "0" : "-1")">
                    People
                </button>
                <button type="button" class="office-tab@(activeTab == "operations" ? " is-active" : string.Empty)" id="office-tab-operations" data-office-tab="operations" role="tab" aria-controls="office-panel-operations" aria-selected="@(activeTab == "operations" ? "true" : "false")" tabindex="@(activeTab == "operations" ? "0" : "-1")">
                    Operations
                </button>
            </div>
            <div class="office-ribbon-body">
                <section class="office-panel" id="office-panel-home" role="tabpanel" aria-labelledby="office-tab-home" data-office-panel="home" @(activeTab == "home" ? string.Empty : "hidden") tabindex="0">
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Home") ? " is-current" : string.Empty)" asp-controller="Home" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-speedometer2"></i></span>
                                <span class="office-command-label">Dashboard</span>
                                <span class="office-command-caption">Portfolio KPIs &amp; alerts</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentController("Properties") && !IsCurrentAction("Properties", "Create") ? " is-current" : string.Empty)" asp-controller="Properties" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-buildings"></i></span>
                                <span class="office-command-label">Manage properties</span>
                                <span class="office-command-caption">Buildings, units &amp; owners</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Portfolio</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Tenants") && !IsCurrentAction("Tenants", "Create") ? " is-current" : string.Empty)" asp-controller="Tenants" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-people"></i></span>
                                <span class="office-command-label">Tenant directory</span>
                                <span class="office-command-caption">Contacts and profiles</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-journal-check"></i></span>
                                <span class="office-command-label">Active leases</span>
                                <span class="office-command-caption">Terms, expirations &amp; status</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Residents</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-credit-card-2-front"></i></span>
                                <span class="office-command-label">Payment ledger</span>
                                <span class="office-command-caption">Receipts and balances</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></span>
                                <span class="office-command-label">Record payment</span>
                                <span class="office-command-caption">Log rent collection</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Financials</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentAction("Properties", "Create") ? " is-current" : string.Empty)" asp-controller="Properties" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-building-add"></i></span>
                                <span class="office-command-label">New property</span>
                                <span class="office-command-caption">Capture a new asset</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-journal-plus"></i></span>
                                <span class="office-command-label">New lease</span>
                                <span class="office-command-caption">Start a contract</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Tenants", "Create") ? " is-current" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-person-plus"></i></span>
                                <span class="office-command-label">Add tenant</span>
                                <span class="office-command-caption">Onboard a resident</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Quick capture</span>
                        </div>
                    </div>
                </section>
                <section class="office-panel" id="office-panel-portfolio" role="tabpanel" aria-labelledby="office-tab-portfolio" data-office-panel="portfolio" @(activeTab == "portfolio" ? string.Empty : "hidden") tabindex="0">
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Properties") && !IsCurrentAction("Properties", "Create") ? " is-current" : string.Empty)" asp-controller="Properties" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-buildings"></i></span>
                                <span class="office-command-label">Properties list</span>
                                <span class="office-command-caption">Overview of each asset</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Properties", "Create") ? " is-current" : string.Empty)" asp-controller="Properties" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-building-add"></i></span>
                                <span class="office-command-label">Add property</span>
                                <span class="office-command-caption">Track a new community</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Asset management</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-clipboard-data"></i></span>
                                <span class="office-command-label">Lease pipeline</span>
                                <span class="office-command-caption">Monitor expirations</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-arrow-repeat"></i></span>
                                <span class="office-command-label">Start renewal</span>
                                <span class="office-command-caption">Extend resident stays</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Occupancy</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Home") ? " is-current" : string.Empty)" asp-controller="Home" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-graph-up"></i></span>
                                <span class="office-command-label">Performance view</span>
                                <span class="office-command-caption">Portfolio KPIs dashboard</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-credit-card-2-front"></i></span>
                                <span class="office-command-label">Receivables</span>
                                <span class="office-command-caption">Rent collected &amp; due</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Insights</span>
                        </div>
                    </div>
                </section>
                <section class="office-panel" id="office-panel-people" role="tabpanel" aria-labelledby="office-tab-people" data-office-panel="people" @(activeTab == "people" ? string.Empty : "hidden") tabindex="0">
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Tenants") && !IsCurrentAction("Tenants", "Create") ? " is-current" : string.Empty)" asp-controller="Tenants" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-card-list"></i></span>
                                <span class="office-command-label">Resident directory</span>
                                <span class="office-command-caption">Profiles, notes &amp; history</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Tenants", "Create") ? " is-current" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-person-plus"></i></span>
                                <span class="office-command-label">Add resident</span>
                                <span class="office-command-caption">Invite a new tenant</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Directory</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-journal-check"></i></span>
                                <span class="office-command-label">Active agreements</span>
                                <span class="office-command-caption">Key contacts &amp; dates</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-pencil-square"></i></span>
                                <span class="office-command-label">Draft lease</span>
                                <span class="office-command-caption">Capture terms &amp; rent</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Lease contacts</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-clipboard-check"></i></span>
                                <span class="office-command-label">Billing status</span>
                                <span class="office-command-caption">Open balances by resident</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></span>
                                <span class="office-command-label">Log payment</span>
                                <span class="office-command-caption">Apply rent or deposits</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Account health</span>
                        </div>
                    </div>
                </section>
                <section class="office-panel" id="office-panel-operations" role="tabpanel" aria-labelledby="office-tab-operations" data-office-panel="operations" @(activeTab == "operations" ? string.Empty : "hidden") tabindex="0">
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Payments") && !IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-credit-card-2-front"></i></span>
                                <span class="office-command-label">Payment log</span>
                                <span class="office-command-caption">Track rent collection</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Payments", "Create") ? " is-current" : string.Empty)" asp-controller="Payments" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-cash-coin"></i></span>
                                <span class="office-command-label">Record receipt</span>
                                <span class="office-command-caption">Apply new payments</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Receivables</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Leases") && !IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-journal-check"></i></span>
                                <span class="office-command-label">Manage leases</span>
                                <span class="office-command-caption">Review terms &amp; renewals</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Leases", "Create") ? " is-current" : string.Empty)" asp-controller="Leases" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-journal-plus"></i></span>
                                <span class="office-command-label">Create lease</span>
                                <span class="office-command-caption">Launch new agreements</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentAction("Tenants", "Create") ? " is-current" : string.Empty)" asp-controller="Tenants" asp-action="Create">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-person-lines-fill"></i></span>
                                <span class="office-command-label">Onboard tenant</span>
                                <span class="office-command-caption">Assign residents to units</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Lease workflow</span>
                        </div>
                    </div>
                    <div class="office-group">
                        <div class="office-group-body">
                            <a class="office-command office-command--large@(IsCurrentController("Home") ? " is-current" : string.Empty)" asp-controller="Home" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-speedometer2"></i></span>
                                <span class="office-command-label">Operations dashboard</span>
                                <span class="office-command-caption">Live performance metrics</span>
                            </a>
                            <a class="office-command office-command--large@(IsCurrentController("Properties") && !IsCurrentAction("Properties", "Create") ? " is-current" : string.Empty)" asp-controller="Properties" asp-action="Index">
                                <span class="office-command-icon" aria-hidden="true"><i class="bi bi-building"></i></span>
                                <span class="office-command-label">Asset registry</span>
                                <span class="office-command-caption">Ensure data accuracy</span>
                            </a>
                        </div>
                        <div class="office-group-footer">
                            <span class="office-group-title">Portfolio tools</span>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </header>

    <main role="main" class="container py-4">
        @RenderBody()
    </main>

    <footer class="bg-light border-top py-3 mt-auto">
        <div class="container text-center text-muted small">
            &copy; @DateTime.Now.Year Rental Manager. Track leases, tenants, and payments at a glance.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/ribbon.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
