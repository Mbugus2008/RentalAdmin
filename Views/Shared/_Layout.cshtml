@{
    var title = ViewData["Title"] as string ?? "Dashboard";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Rental Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="ribbon shadow-sm">
        <div class="container-fluid px-4">
            <div class="ribbon-header d-flex flex-wrap align-items-center gap-3">
                <div class="ribbon-brand">
                    <a class="ribbon-brand-link" asp-controller="Home" asp-action="Index">Rental Manager</a>
                    <span class="ribbon-tagline">Portfolio Console</span>
                </div>
                <div class="ribbon-quick-actions ms-auto d-none d-md-flex gap-2">
                    <a class="btn btn-outline-light btn-sm" asp-controller="Properties" asp-action="Create">New Property</a>
                    <a class="btn btn-light btn-sm" asp-controller="Leases" asp-action="Create">New Lease</a>
                </div>
            </div>
            <nav class="ribbon-tabs mt-4" aria-label="Primary">
                <div class="ribbon-group">
                    <span class="ribbon-group-title">Portfolio</span>
                    <div class="ribbon-buttons">
                        <a class="ribbon-button @(controller == "Home" ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">
                            <span class="ribbon-button-label">Dashboard</span>
                            <span class="ribbon-button-desc">KPIs & insights</span>
                        </a>
                        <a class="ribbon-button @(controller == "Properties" ? "active" : string.Empty)" asp-controller="Properties" asp-action="Index">
                            <span class="ribbon-button-label">Properties</span>
                            <span class="ribbon-button-desc">Buildings & units</span>
                        </a>
                    </div>
                </div>
                <div class="ribbon-group">
                    <span class="ribbon-group-title">Relationships</span>
                    <div class="ribbon-buttons">
                        <a class="ribbon-button @(controller == "Tenants" ? "active" : string.Empty)" asp-controller="Tenants" asp-action="Index">
                            <span class="ribbon-button-label">Tenants</span>
                            <span class="ribbon-button-desc">Directory & history</span>
                        </a>
                    </div>
                </div>
                <div class="ribbon-group">
                    <span class="ribbon-group-title">Operations</span>
                    <div class="ribbon-buttons">
                        <a class="ribbon-button @(controller == "Leases" ? "active" : string.Empty)" asp-controller="Leases" asp-action="Index">
                            <span class="ribbon-button-label">Leases</span>
                            <span class="ribbon-button-desc">Terms & expirations</span>
                        </a>
                        <a class="ribbon-button @(controller == "Payments" ? "active" : string.Empty)" asp-controller="Payments" asp-action="Index">
                            <span class="ribbon-button-label">Payments</span>
                            <span class="ribbon-button-desc">Ledger activity</span>
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <main role="main" class="container py-4">
        @RenderBody()
    </main>

    <footer class="bg-light border-top py-3 mt-auto">
        <div class="container text-center text-muted small">
            &copy; @DateTime.Now.Year Rental Manager. Track leases, tenants, and payments at a glance.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
