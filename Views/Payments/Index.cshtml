@model IEnumerable<Payment>
@{
    ViewData["Title"] = "Payments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Payments</h1>
    <a class="btn btn-primary" asp-action="Create">Record Payment</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Property</th>
                    <th>Tenant</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>@payment.Lease?.Property?.Name</td>
                        <td>@payment.Lease?.Tenant?.FullName</td>
                        <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                        <td>@payment.Amount.ToString("C")</td>
                        <td>@payment.Method</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@payment.Id">Edit</a>
                                <form asp-action="Delete" asp-route-id="@payment.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this payment?');">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
