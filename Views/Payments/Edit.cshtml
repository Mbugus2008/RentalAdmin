@model Payment
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Edit Payment";
    var leases = ViewData["LeaseId"] as SelectList;
}

<h1 class="h3 mb-3">Edit Payment</h1>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="LeaseId" class="form-label"></label>
                    <select asp-for="LeaseId" class="form-select" asp-items="leases"></select>
                    <span asp-validation-for="LeaseId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentDate" class="form-label"></label>
                    <input asp-for="PaymentDate" class="form-control" type="date" />
                    <span asp-validation-for="PaymentDate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Amount" class="form-label"></label>
                    <input asp-for="Amount" class="form-control" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Method" class="form-label"></label>
                    <input asp-for="Method" class="form-control" />
                    <span asp-validation-for="Method" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>
            </div>
            <div class="mt-4 d-flex justify-content-between">
                <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Update Payment</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
