@model IEnumerable<Lease>
@{
    ViewData["Title"] = "Leases";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Leases</h1>
    <a class="btn btn-primary" asp-action="Create">Add Lease</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Property</th>
                    <th>Tenant</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Rent</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lease in Model)
                {
                    <tr>
                        <td>@lease.Property?.Name</td>
                        <td>@lease.Tenant?.FullName</td>
                        <td>@lease.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@lease.EndDate?.ToString("MMM dd, yyyy")</td>
                        <td>@lease.MonthlyRent.ToString("C")</td>
                        <td><span class="badge bg-secondary">@lease.Status</span></td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@lease.Id">Details</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@lease.Id">Edit</a>
                                <form asp-action="Delete" asp-route-id="@lease.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this lease?');">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
